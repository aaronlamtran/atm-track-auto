# ATM Login
ATM_LOGIN_URL=https://www.switchcommerce.net/TMS/Login.aspx
ATM_USERNAME=your_username
ATM_PASSWORD=your_password

# Terminal to monitor
# Log in manually, click your terminal, copy the URL from the address bar
ATM_TERMINAL_URL=https://www.switchcommerce.net/TMS/App/terminals/view_overview.aspx?TerminalID=YOUR_TERMINAL_ID

# Alert settings
ALERT_THRESHOLD=2000
CHECK_INTERVAL_MINUTES=5

# Email (Yahoo App Password — not your regular password)
# Generate at: Yahoo Account → Security → App Passwords
SMTP_EMAIL=you@yahoo.com
SMTP_PASSWORD=your_app_password

# Alert recipient (email or SMS gateway, e.g. 5551234567@tmomail.net)
# SMS gateways: AT&T=@txt.att.net  T-Mobile=@tmomail.net  Verizon=@vtext.com
ALERT_TO=you@email.com
